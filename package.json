{
  "name": "maintainerkit",
  "version": "0.1.4",
  "description": "Prepare repositories for safe AI-assisted maintenance.",
  "author": "fishfillet-krm",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fishfillet-krm/maintainerkit.git"
  },
  "homepage": "https://github.com/fishfillet-krm/maintainerkit#readme",
  "bugs": {
    "url": "https://github.com/fishfillet-krm/maintainerkit/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "maintainerkit": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/set-bin-mode.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "node scripts/cli-smoke.mjs",
    "test:package": "node scripts/package-smoke.mjs",
    "case-studies": "npm run build && node scripts/run-case-studies.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "npm run lint && npm run test:coverage && npm run build && npm run format:check && npm run test:e2e && npm run test:package",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.34.2",
  "license": "MIT",
  "keywords": [
    "codex",
    "oss",
    "maintenance",
    "cli",
    "ai"
  ],
  "dependencies": {
    "commander": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.29",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.28.1"
    }
  }
}
